{
  "name": "@trader-block/app",
  "version": "1.0.0",
  "description": "Electron GUI application for Trader Browser Block",
  "main": "dist/main.js",
  "homepage": "./",
  "scripts": {
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite --port 5173",
    "start": "electron dist/main.js",
    "electron:dev": "concurrently \"npm run dev:main\" \"wait-on dist/main.js && electron dist/main.js\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "clean": "rimraf dist build"
  },
  "dependencies": {
    "@trader-block/core": "^1.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.0",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/material": "^5.15.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/x-date-pickers": "^6.18.3",
    "dayjs": "^1.11.10"
  },
  "build": {
    "appId": "com.traderblock.app",
    "productName": "Trader Browser Block",
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "directories": {
      "output": "../../dist"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "default",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true
    }
  }
} 